{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://make-harness.local/schemas/summary_report.schema.json",
  "title": "Summary Report",
  "description": "Final summary produced by summary_worker after all orchestration work is complete.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "status",
    "명령",
    "수행 사전 작업",
    "수행 내용",
    "수행 결과",
    "risks_or_follow_up"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "default": "1.0.0"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "completed",
        "blocked"
      ]
    },
    "명령": {
      "$ref": "#/$defs/string_list_nonempty"
    },
    "수행 사전 작업": {
      "$ref": "#/$defs/string_list_nonempty"
    },
    "수행 내용": {
      "$ref": "#/$defs/string_list_nonempty"
    },
    "수행 결과": {
      "$ref": "#/$defs/string_list_nonempty"
    },
    "risks_or_follow_up": {
      "$ref": "#/$defs/string_list"
    }
  },
  "$defs": {
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "string_list_nonempty": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
