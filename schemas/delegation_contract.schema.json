{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://make-harness.local/schemas/delegation_contract.schema.json",
  "title": "Delegation Contract",
  "description": "Assignment passed from the main orchestrator to a worker.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "objective",
    "assigned_scope",
    "inputs",
    "allowed_files",
    "path_normalization_policy",
    "symlink_policy",
    "secret_handling_policy",
    "network_cost_policy",
    "prohibited_actions",
    "expected_outputs",
    "verification",
    "reporting_format"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "default": "1.0.0"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "enum": [
        "goal_refiner",
        "goal_review_worker",
        "subtask_worker",
        "review_worker",
        "verification_worker",
        "summary_worker",
        "security_agent",
        "technical_agent",
        "management_agent"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "assigned_scope": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_files": {
      "$ref": "#/$defs/path_list"
    },
    "path_normalization_policy": {
      "$ref": "#/$defs/path_normalization_policy"
    },
    "symlink_policy": {
      "$ref": "#/$defs/symlink_policy"
    },
    "secret_handling_policy": {
      "$ref": "#/$defs/secret_handling_policy"
    },
    "network_cost_policy": {
      "$ref": "#/$defs/network_cost_policy"
    },
    "prohibited_actions": {
      "$ref": "#/$defs/string_list_nonempty"
    },
    "expected_outputs": {
      "$ref": "#/$defs/string_list_nonempty"
    },
    "verification": {
      "oneOf": [
        {
          "$ref": "#/$defs/string_list_nonempty"
        },
        {
          "$ref": "#/$defs/verification_matrix"
        }
      ]
    },
    "reporting_format": {
      "type": "string",
      "minLength": 1
    },
    "iteration_budget": {
      "$ref": "#/$defs/iteration_budget"
    }
  },
  "$defs": {
    "string_list_nonempty": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "path_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/safe_relative_path"
      }
    },
    "safe_relative_path": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {
          "not": {
            "pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)"
          }
        },
        {
          "not": {
            "pattern": "^[A-Za-z]:"
          }
        },
        {
          "not": {
            "pattern": "^[\\\\/]"
          }
        },
        {
          "not": {
            "pattern": "^~"
          }
        },
        {
          "not": {
            "pattern": "%[A-Za-z_][A-Za-z0-9_]*%"
          }
        },
        {
          "not": {
            "pattern": "\\$\\{?(env:)?[A-Za-z_][A-Za-z0-9_]*\\}?"
          }
        },
        {
          "not": {
            "pattern": "[*?\\[\\]]"
          }
        }
      ]
    },
    "path_normalization_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "workspace_relative_only",
        "reject_parent_directory_segments",
        "reject_absolute_paths",
        "reject_workspace_escape",
        "reject_globs"
      ],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true
        },
        "workspace_relative_only": {
          "type": "boolean",
          "const": true
        },
        "reject_parent_directory_segments": {
          "type": "boolean",
          "const": true
        },
        "reject_absolute_paths": {
          "type": "boolean",
          "const": true
        },
        "reject_workspace_escape": {
          "type": "boolean",
          "const": true
        },
        "reject_globs": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "symlink_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolve_before_access",
        "reject_targets_outside_workspace"
      ],
      "properties": {
        "resolve_before_access": {
          "type": "boolean",
          "const": true
        },
        "reject_targets_outside_workspace": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "secret_handling_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secret_scan_required",
        "mask_secret_candidates",
        "reject_raw_secret_output"
      ],
      "properties": {
        "secret_scan_required": {
          "type": "boolean",
          "const": true
        },
        "mask_secret_candidates": {
          "type": "boolean",
          "const": true
        },
        "reject_raw_secret_output": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "network_cost_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_default",
        "external_cost_default",
        "explicit_approval_required"
      ],
      "properties": {
        "network_default": {
          "const": "denied"
        },
        "external_cost_default": {
          "const": "denied"
        },
        "explicit_approval_required": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "verification_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "build",
        "lint",
        "test",
        "run",
        "behavior_check"
      ],
      "properties": {
        "build": {
          "type": "string",
          "minLength": 1
        },
        "lint": {
          "type": "string",
          "minLength": 1
        },
        "test": {
          "type": "string",
          "minLength": 1
        },
        "run": {
          "type": "string",
          "minLength": 1
        },
        "behavior_check": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "iteration_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_iterations",
        "max_rework_iterations",
        "default_consensus_rounds",
        "max_consensus_rounds",
        "max_subagents_per_task",
        "max_open_subagents",
        "max_validation_failures",
        "max_wall_clock_minutes",
        "min_completion_score"
      ],
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1,
          "default": 8
        },
        "max_rework_iterations": {
          "type": "integer",
          "minimum": 0,
          "default": 6
        },
        "default_consensus_rounds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3,
          "default": 2
        },
        "max_consensus_rounds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3,
          "default": 3
        },
        "max_subagents_per_task": {
          "type": "integer",
          "minimum": 1,
          "default": 16
        },
        "max_open_subagents": {
          "type": "integer",
          "minimum": 1,
          "default": 6
        },
        "max_validation_failures": {
          "type": "integer",
          "minimum": 0,
          "default": 3
        },
        "max_wall_clock_minutes": {
          "type": "integer",
          "minimum": 1,
          "default": 180
        },
        "min_completion_score": {
          "type": "integer",
          "minimum": 85,
          "maximum": 100,
          "default": 85
        }
      }
    }
  }
}
